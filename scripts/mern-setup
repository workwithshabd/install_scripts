#!/usr/bin/env bash
set -e

# -------- HELP --------
show_help() {
  echo ""
  echo "MERN Setup CLI"
  echo ""
  echo "Usage:"
  echo "  mern-setup [project] [mongo_uri] [jwt_secret] [frontend_url]"
  echo ""
}

if [[ "${1:-}" == "-help" || "${1:-}" == "--help" ]]; then
  show_help
  exit 0
fi

echo ""
echo "==========================================="
echo "        MERN Setup"
echo "==========================================="
echo ""

# -------- DEPENDENCY CHECK --------
if ! command -v node >/dev/null 2>&1; then
  echo "❌ Node.js not installed"
  exit 1
fi

if ! command -v npm >/dev/null 2>&1; then
  echo "❌ npm not installed"
  exit 1
fi

# -------- INPUT --------
APP_NAME=${1:-}
MONGO_URI=${2:-}
JWT_SECRET=${3:-}
FRONTEND_URL=${4:-}

# -------- INTERACTIVE FALLBACK --------
if [[ -z "$APP_NAME" ]]; then
  read -p "Project name (default: mern-app): " INPUT < /dev/tty
  APP_NAME=${INPUT:-mern-app}
fi

if [[ -z "$MONGO_URI" ]]; then
  read -p "MongoDB URI: " INPUT < /dev/tty
  MONGO_URI=${INPUT:-your_mongodb_connection_string_here}
fi

if [[ -z "$JWT_SECRET" ]]; then
  read -p "JWT Secret (default: devsecret): " INPUT < /dev/tty
  JWT_SECRET=${INPUT:-devsecret}
fi

if [[ -z "$FRONTEND_URL" ]]; then
  read -p "Frontend URL (default: http://localhost:5173): " INPUT < /dev/tty
  FRONTEND_URL=${INPUT:-http://localhost:5173}
fi

# -------- CONFIRM --------
echo ""
echo "-------------------------------------------"
echo "Project: $APP_NAME"
echo "Mongo URI: $MONGO_URI"
echo "Frontend URL: $FRONTEND_URL"
echo "-------------------------------------------"

read -p "Continue? (y/n): " CONFIRM < /dev/tty
[[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]] && echo "Cancelled." && exit 0

# -------- ROOT --------
mkdir "$APP_NAME"
cd "$APP_NAME"

# =========================
# BACKEND
# =========================
echo "Setting up backend..."
mkdir backend && cd backend

npm init -y >/dev/null
npm install express mongoose cors dotenv >/dev/null
npm install nodemon --save-dev >/dev/null

node -e "
let pkg=require('./package.json');
pkg.scripts={dev:'nodemon server.js',start:'node server.js'};
require('fs').writeFileSync('package.json', JSON.stringify(pkg,null,2));
"

mkdir controllers models routes middleware

cat <<EOF > server.js
const express = require('express');
const mongoose = require('mongoose');
require('dotenv').config();

const app = express();
app.use(require('cors')({ origin: process.env.FRONTEND_URL }));

app.get('/api', (req,res)=>res.json({message:'API running'}));

mongoose.connect(process.env.MONGO_URI)
.then(()=>console.log('MongoDB Connected'))
.catch(console.error);

app.listen(5000, ()=>console.log('Server running on 5000'));
EOF

cat <<EOF > .env
PORT=5000
MONGO_URI=$MONGO_URI
JWT_SECRET=$JWT_SECRET
FRONTEND_URL=$FRONTEND_URL
EOF

cd ..

# =========================
# FRONTEND
# =========================
echo "Setting up frontend..."

# --- VITE FIX ---
if npm create vite@latest frontend -- --template react >/dev/null 2>&1; then
  echo "Vite created via npm"
else
  echo "Fallback: using npx"
  npx --yes create-vite@latest frontend --template react
fi

cd frontend

npm install >/dev/null
npm install -D tailwindcss postcss autoprefixer >/dev/null

# --- TAILWIND FIX ---
echo "Initializing Tailwind..."

if npx --yes tailwindcss init -p >/dev/null 2>&1; then
  echo "Tailwind initialized via npx"
elif [ -f "./node_modules/.bin/tailwindcss" ]; then
  ./node_modules/.bin/tailwindcss init -p
  echo "Tailwind initialized via local binary"
else
  echo "❌ Tailwind CLI failed"
  exit 1
fi

# config files
cat <<EOF > tailwind.config.js
export default {
  content: ["./index.html","./src/**/*.{js,jsx}"],
  theme: { extend: {} },
  plugins: [],
}
EOF

cat <<EOF > src/index.css
@tailwind base;
@tailwind components;
@tailwind utilities;
EOF

cat <<EOF > src/App.jsx
export default function App(){
  return (
    <div className="h-screen flex items-center justify-center">
      <h1 className="text-3xl font-bold text-blue-600">
        MERN Ready 🚀
      </h1>
    </div>
  )
}
EOF

cd ..

# =========================
# SUCCESS
# =========================
echo ""
echo "==========================================="
echo "   ✅ MERN Project Created Successfully"
echo "==========================================="
echo ""
echo "cd $APP_NAME/backend && npm run dev"
echo "cd $APP_NAME/frontend && npm run dev"
echo ""
echo "Frontend: http://localhost:5173"
echo "Backend:  http://localhost:5000/api"
echo ""