#!/usr/bin/env bash

set -e

SETUP_MARKER=".mysql_setup_done"
MYSQL_ROOT_PASSWORD="rootuser"

# ---------- HELP ----------

show_help() {
cat <<EOF

MySQL Setup Script

USAGE:
  ./mysql-setup          Run setup (first time only)
  ./mysql-setup --help   Show this help
  ./mysql-setup --reset  Remove MySQL completely (DANGEROUS)
  ./mysql-setup --change-password  Change root password

DEFAULT LOGIN (after setup):
  mysql -u root -p
  password: rootuser (unless changed)

EOF
}

# ---------- SUDO ----------

keep_sudo_alive() {
  sudo -v
  while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &
}

# ---------- CHANGE PASSWORD ----------

change_password() {
  read -s -p "Enter current root password: " CURRENT
  echo
  read -s -p "Enter new password: " NEWPASS
  echo

  mysql -u root -p"$CURRENT" <<EOF
ALTER USER 'root'@'localhost' IDENTIFIED WITH mysql_native_password BY '$NEWPASS';
FLUSH PRIVILEGES;
EOF

  echo "✅ Password updated successfully."
}

# ---------- RESET ----------

reset_mysql() {
  echo "⚠️ This will DELETE MySQL and ALL data."
  read -p "Type DELETE to confirm: " confirm

  [[ "$confirm" != "DELETE" ]] && echo "Aborted." && exit 1

  mysql.server stop || true
  brew services stop mysql || true

  brew uninstall mysql || true
  brew cleanup

  sudo rm -rf /usr/local/var/mysql
  sudo rm -rf /opt/homebrew/var/mysql
  sudo rm -rf /opt/homebrew/etc/my.cnf
  sudo rm -rf /usr/local/etc/my.cnf

  rm -f "$SETUP_MARKER"

  echo "Reset complete."
}

# ---------- VERIFY ----------

verify_setup() {
  echo "Verifying setup..."

  if mysql -u root -p"$MYSQL_ROOT_PASSWORD" -e "SELECT 1;" >/dev/null 2>&1; then
    echo "✅ MySQL working with default password."
  else
    echo "⚠️ MySQL working but password changed by user."
  fi
}

# ---------- ARGUMENTS ----------

case "$1" in
  --help) show_help; exit 0 ;;
  --reset) keep_sudo_alive; reset_mysql; exit 0 ;;
  --change-password) change_password; exit 0 ;;
esac

# ---------- PREVENT RE-RUN ----------

if [[ -f "$SETUP_MARKER" ]]; then
  echo "MySQL already configured."
  echo "Use --help for options."
  exit 0
fi

# ---------- SETUP ----------

echo "Requesting sudo..."
keep_sudo_alive

echo "Installing MySQL if needed..."
if ! command -v mysql >/dev/null 2>&1; then
  brew install mysql
else
  echo "MySQL already installed."
fi

echo "Starting MySQL..."
mysql.server start || true
sleep 5

# ---------- PASSWORD LOGIC ----------

echo "Configuring root password..."

if mysql -u root -e "SELECT 1;" >/dev/null 2>&1; then
  echo "Fresh install detected → setting default password."

  mysql -u root <<EOF
ALTER USER 'root'@'localhost' IDENTIFIED WITH mysql_native_password BY '${MYSQL_ROOT_PASSWORD}';
FLUSH PRIVILEGES;
EOF

elif mysql -u root -p"$MYSQL_ROOT_PASSWORD" -e "SELECT 1;" >/dev/null 2>&1; then
  echo "Password already set to default."

else
  echo "⚠️ Existing password detected. Skipping password setup."
fi

# ---------- CLEANUP ----------

if mysql -u root -p"$MYSQL_ROOT_PASSWORD" -e "SELECT 1;" >/dev/null 2>&1; then
  echo "Cleaning default insecure settings..."

  mysql -u root -p"$MYSQL_ROOT_PASSWORD" <<EOF
DELETE FROM mysql.user WHERE User='';
DROP DATABASE IF EXISTS test;
DELETE FROM mysql.db WHERE Db='test' OR Db='test\\_%';
FLUSH PRIVILEGES;
EOF
fi

# ---------- VERIFY ----------

verify_setup

# ---------- MARK COMPLETE ----------

touch "$SETUP_MARKER"

echo
echo "🎉 Setup completed."
echo
echo "Login:"
echo "mysql -u root -p"
echo "Password: rootuser (if unchanged)"
echo
show_help